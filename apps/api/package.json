{
  "name": "@starter/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-presigned-post": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@starter/db": "workspace:*",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.7.11",
    "ioredis": "^5.4.2",
    "mathjs": "^15.2.0",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "resend": "^6.12.2",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}
