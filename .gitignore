# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnpm-store/
.pnpm-debug.log*

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
dist/
build/
.next/
out/
.output/
.vercel/
.netlify/

# Turbo
.turbo/

# TypeScript
*.tsbuildinfo

# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
# Keep the example file
!.env.example

# =============================================================================
# DATABASE
# =============================================================================
# Drizzle migrations meta (auto-generated)
drizzle/meta/
# SQLite local dev db
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# =============================================================================
# AUTH
# =============================================================================
# Better Auth generated files (if any local cache)
.better-auth/

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
coverage/
.nyc_output/
test-results/
playwright-report/
.vitest-cache/

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# IDE & EDITORS
# =============================================================================
# VSCode — only ignore user-specific settings, not shared workspace config
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.fuse_hidden*
.Trash-*

# =============================================================================
# PACKAGE MANAGER
# =============================================================================
# Don't ignore pnpm-lock.yaml — always commit lockfiles
.yarn/
.yarn-integrity

# =============================================================================
# MISC
# =============================================================================
*.tgz
*.tar.gz
.cache/
tmp/
temp/
