{
  "name": "starter",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "pnpm --filter @starter/db push",
    "db:studio": "pnpm --filter @starter/db studio",
    "db:generate": "pnpm --filter @starter/db generate",
    "db:reset": "docker compose down -v --remove-orphans && docker compose up -d && sleep 3 && pnpm db:push && pnpm db:seed",
    "db:seed": "pnpm --filter @starter/db seed",
    "db:seed:sst": "pnpm --filter @starter/db seed:sst"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
